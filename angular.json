{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm"
  },
  "newProjectRoot": "projects",
  "projects": {
    "al-sahel-repair": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "src/main.ts",
            "tsConfig": "tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              }
            ],
            "styles": [
              "public/lib/animate/animate.min.css",
              "public/lib/owlcarousel/assets/owl.carousel.min.css",
              "src/styles.scss"
            ],
            "scripts": [
              "public/lib/wow/wow.min.js",
              "public/lib/easing/easing.min.js",
              "public/lib/waypoints/waypoints.min.js",
              "public/lib/owlcarousel/owl.carousel.min.js",
              "public/lib/counterup/counterup.min.js",
              "public/lib/parallax/parallax.min.js"
            ],
            "stylePreprocessorOptions": {
              "includePaths": ["src/scss"]
            }
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "1MB",
                  "maximumError": "2MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "20kB",
                  "maximumError": "40kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "options": {
            "allowedHosts": ["reforest-overtone-scroll.ngrok-free.dev"]
          },
          "configurations": {
            "production": {
              "buildTarget": "al-sahel-repair:build:production"
            },
            "development": {
              "buildTarget": "al-sahel-repair:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test"
        }
      }
    }
  }
}
